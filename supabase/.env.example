# Supabase Environment Variables
# Copy this file to .env and fill in your values

# Get these from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Get from Supabase Dashboard → Settings → Edge Functions
# No additional env vars needed for basic functions

# Apify API Token (for market research)
# Get from https://apify.com/settings/integrations
APIFY_API_TOKEN=your-apify-token

# Resend API Key (for sending emails)
# Get from https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Optional: OpenAI API Key (for AI-powered negotiation)
# Only needed if using AI features
OPENAI_API_KEY=your-openai-key

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================

# 1. Run the schema in Supabase SQL Editor:
#    Copy contents of supabase/schema.sql and run in SQL Editor

# 2. Deploy Edge Functions:
#    cd supabase/functions
#    supabase functions deploy process-csv
#    supabase functions deploy market-research
#    supabase functions deploy underwrite-property
#    supabase functions deploy generate-offer
#    supabase functions deploy send-email
#    supabase functions deploy dispo-match

# 3. Set environment secrets:
#    supabase secrets set APIFY_API_TOKEN=your-token
#    supabase secrets set RESEND_API_KEY=your-key
